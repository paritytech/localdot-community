# LocalDOT Web App Environment Variables — Paseo Next v2 stack
# Copy this to .env.local: cp .env.example .env.local
#
# All defaults already point at public Paseo Next v2 endpoints, so the
# only values you NEED to override are contract addresses after a fresh
# deploy. Endpoints can stay as-is.

# Paseo Asset Hub Next (EVM-side via eth-rpc proxy, ethers reads chainId here)
VITE_RPC_URL=https://eth-rpc-paseo-next.polkadot.io
VITE_CHAIN_ID=420420417
VITE_NETWORK_NAME=Paseo Asset Hub Next

# Paseo Asset Hub Next (Substrate WSS — PAPI / Revive.call live here)
VITE_ASSET_HUB_ENDPOINT=wss://paseo-asset-hub-next-rpc.polkadot.io

# Contracts deployed on Paseo Asset Hub Next
VITE_P2PMARKET_ADDRESS=
VITE_ZKPASSPORT_REGISTRY_ADDRESS=0xAA7C4b07c7040D31e40ad60E9e35257E376BD717

# Paseo Bulletin Next (storage + hop_submit RPC)
VITE_BULLETIN_ENDPOINT=wss://paseo-bulletin-next-rpc.polkadot.io

# Paseo People Next System (Statement Store host chain — statement_* RPC)
VITE_PEOPLE_CHAIN_ENDPOINT=wss://paseo-people-next-system-rpc.polkadot.io

# Paseo Next v2 IPFS Gateway (Bulletin-backed)
VITE_IPFS_GATEWAY=https://paseo-bulletin-next-ipfs.polkadot.io/ipfs/
