{
  "name": "localdot",
  "version": "1.0.0",
  "private": true,
  "description": "Peer-to-peer cash-to-token exchange on Polkadot",
  "license": "GPL-3.0-only",
  "repository": {
    "type": "git",
    "url": "https://github.com/paritytech/localdot-community.git"
  },
  "homepage": "https://github.com/paritytech/localdot-community#readme",
  "bugs": {
    "url": "https://github.com/paritytech/localdot-community/issues"
  },
  "author": "Parity Technologies <admin@parity.io>",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "lint:fix": "turbo run lint:fix",
    "format": "prettier --write \"**/*.{ts,tsx,md,json,sol}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,md,json,sol}\"",
    "fix": "pnpm lint:fix && pnpm format",
    "typecheck": "turbo run typecheck",
    "clean": "turbo run clean && rm -rf node_modules",
    "contracts:compile": "pnpm --filter @localdot/contracts compile",
    "contracts:test": "pnpm --filter @localdot/contracts test",
    "contracts:deploy": "pnpm --filter @localdot/contracts deploy",
    "contracts:seed": "pnpm --filter @localdot/contracts seed",
    "download:binaries": "pnpm --filter @localdot/contracts download:binaries",
    "web:dev": "pnpm --filter @localdot/web dev",
    "web:build": "pnpm --filter @localdot/web build",
    "web:preview": "pnpm --filter @localdot/web preview",
    "deploy": "node scripts/deploy-bootstrap.mjs"
  },
  "devDependencies": {
    "@localdot/config": "workspace:*",
    "@polkadot-labs/hdkd": "^0.0.11",
    "@polkadot-labs/hdkd-helpers": "^0.0.11",
    "@polkadot/util-crypto": "^14.0.0",
    "@types/node": "^20.10.0",
    "dotenv": "^16.4.5",
    "ethers": "^6.10.0",
    "hardhat": "^2.28.2",
    "eslint": "^9.0.0",
    "polkadot-api": "^2.1.5",
    "prettier": "^3.1.0",
    "prettier-plugin-solidity": "^1.3.1",
    "tsx": "^4.19.2",
    "turbo": "^2.9.14",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=10.0.0"
  },
  "packageManager": "pnpm@10.8.0",
  "pnpm": {
    "overrides": {
      "micro-eth-signer": "0.16.0",
      "@types/react": "18.3.26",
      "@types/react-dom": "18.3.7",
      "@polkadot-api/cli": "0.21.4"
    },
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
