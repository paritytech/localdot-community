{
  "name": "@localdot/bulletin",
  "version": "1.0.0",
  "private": true,
  "description": "Bulletin Chain integration for localdot",
  "license": "GPL-3.0-only",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "papi && tsc",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@noble/hashes": "^1.7.1",
    "@polkadot-api/descriptors": "file:.papi/descriptors",
    "@polkadot-labs/hdkd": "^0.0.11",
    "@polkadot-labs/hdkd-helpers": "^0.0.11",
    "multiformats": "^13.3.1",
    "polkadot-api": "^2.1.5"
  },
  "devDependencies": {
    "@localdot/config": "workspace:*",
    "@polkadot-api/cli": "^0.21.4",
    "typescript": "^5.9.3"
  }
}
