{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "lib": ["ES2022"],
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "outDir": "./dist",
    "rootDir": "./",
    "composite": true
  },
  "include": ["lib/**/*", "typechain-types/**/*", "scripts/**/*", "test/**/*", "hardhat.config.ts"],
  "exclude": ["node_modules", "artifacts", "cache"],
  "references": [{ "path": "../types" }]
}
